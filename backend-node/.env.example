# Server
PORT=8080
NODE_ENV=production

# Database (PostgreSQL - Supabase, Neon, or Render)
DATABASE_URL=postgresql://user:password@host:5432/vishwakarma_db

# Clerk Authentication
CLERK_SECRET_KEY=sk_live_YOUR_CLERK_SECRET_KEY
CLERK_PUBLISHABLE_KEY=pk_live_YOUR_CLERK_PUBLISHABLE_KEY

# JWT (fallback if Clerk is not used for server-to-server)
JWT_SECRET=your-jwt-secret-change-in-production

# CORS
FRONTEND_URL=https://your-site.netlify.app

# File Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
